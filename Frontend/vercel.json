{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {},
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/uploads/:path*",
      "destination": "https://anova-tecnologes-production.railway.app/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}

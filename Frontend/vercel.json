{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://anova-tecnologes-production.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://anova-tecnologes-production.railway.app/uploads/$1"
    },
    {
      "source": "(.*)",
      "destination": "/index.html"
    }
  ]
}

{
  "rewrites": [
    {
      "source": "/google(.*).html",
      "destination": "/google$1.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://anova-tecnologes-production.railway.app/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://anova-tecnologes-production.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
